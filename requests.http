# ─────────────────────────────────────────────────────────────────────────────
# MAILBOX MAPPINGS  (PK: AssignmentId INT64)
# ─────────────────────────────────────────────────────────────────────────────

### List all mailbox mappings
GET {{baseUrl}}/api/mailbox-mappings

### Filter by mailbox
GET {{baseUrl}}/api/mailbox-mappings?MailboxId=1

### Get one mailbox mapping
GET {{baseUrl}}/api/mailbox-mappings/1

### Create a mailbox mapping
POST {{baseUrl}}/api/mailbox-mappings
Content-Type: application/json

{
  "MailboxId": 1,
  "UserId": 1,
  "LoBId": 1,
  "CountryId": 1
}

### Update a mailbox mapping
PUT {{baseUrl}}/api/mailbox-mappings/1
Content-Type: application/json

{
  "MailboxId": 1,
  "UserId": 2,
  "LoBId": 1,
  "CountryId": 1
}

### Delete a mailbox mapping
DELETE {{baseUrl}}/api/mailbox-mappings/1



# ─────────────────────────────────────────────────────────────────────────────
# EMAILS  (PK: ItemId STRING/UUID)
# ─────────────────────────────────────────────────────────────────────────────

### List all emails
GET {{baseUrl}}/api/emails

### List with pagination
GET {{baseUrl}}/api/emails?page=1&limit=20

### Filter by status
GET {{baseUrl}}/api/emails?StatusId=1

### Filter by category
GET {{baseUrl}}/api/emails?CategoryId=1

### Filter by assigned user
GET {{baseUrl}}/api/emails?AssignedToId=1

### Filter by assignment
GET {{baseUrl}}/api/emails?AssignmentId=1

### Filter by sender
GET {{baseUrl}}/api/emails?EmailFrom=someone@example.com

### Get one email
GET {{baseUrl}}/api/emails/your-item-uuid-here

### Create an email (ItemId auto-generated if omitted)
POST {{baseUrl}}/api/emails
Content-Type: application/json

{
  "Subject": "Test email subject",
  "EmailFrom": "sender@example.com",
  "EmailTo": "claims@aon.com",
  "EmailReceivedOn": "2026-04-15T10:00:00Z",
  "StatusId": 1,
  "CategoryId": 1,
  "AssignedToId": 1,
  "AssignmentId": 1,
  "Attachments": []
}

### Create an email with attachments
POST {{baseUrl}}/api/emails
Content-Type: application/json

{
  "Subject": "Email with attachment",
  "EmailFrom": "sender@example.com",
  "EmailTo": "claims@aon.com",
  "EmailReceivedOn": "2026-04-15T10:00:00Z",
  "StatusId": 1,
  "CategoryId": 1,
  "AssignedToId": 1,
  "AssignmentId": 1,
  "Attachments": [
    {
      "FileName": "document.pdf",
      "FileSize": 102400,
      "ContentType": "application/pdf",
      "AttachmentId": "att-uuid-here"
    }
  ]
}

### Update an email (scalar fields)
PUT {{baseUrl}}/api/emails/your-item-uuid-here
Content-Type: application/json

{
  "StatusId": 2,
  "CategoryId": 1,
  "AssignedToId": 1
}

### Update an email (including attachments)
PUT {{baseUrl}}/api/emails/your-item-uuid-here
Content-Type: application/json

{
  "StatusId": 2,
  "Attachments": [
    {
      "FileName": "updated.pdf",
      "FileSize": 204800,
      "ContentType": "application/pdf",
      "AttachmentId": "att-uuid-here"
    }
  ]
}

### Delete an email
DELETE {{baseUrl}}/api/emails/your-item-uuid-here



# ─────────────────────────────────────────────────────────────────────────────
# EVENTS  (PK: EventRecordId INT64 — append-only, no PUT)
# ─────────────────────────────────────────────────────────────────────────────

### List all events
GET {{baseUrl}}/api/events

### List with pagination
GET {{baseUrl}}/api/events?page=1&limit=20

### Get events for a specific email (by ItemId)
GET {{baseUrl}}/api/events/by-item/your-item-uuid-here

### Get one event
GET {{baseUrl}}/api/events/1

### Create an event
POST {{baseUrl}}/api/events
Content-Type: application/json

{
  "ItemId": "your-item-uuid-here",
  "EventId": 1,
  "UserId": 1,
  "Notes": "Email assigned to claims team"
}

### Delete an event
DELETE {{baseUrl}}/api/events/1
