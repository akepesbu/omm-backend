@baseUrl = https://omm-backend-837517257785.europe-west1.run.app

# ─────────────────────────────────────────────────────────────────────────────
# HEALTH
# ─────────────────────────────────────────────────────────────────────────────

### Health check
GET {{baseUrl}}/health



# ─────────────────────────────────────────────────────────────────────────────
# STATUS  (PK: StatusId INT64)
# ─────────────────────────────────────────────────────────────────────────────

### List all statuses
GET {{baseUrl}}/api/status

### List with pagination
GET {{baseUrl}}/api/status?page=1&limit=10

### Get one status
GET {{baseUrl}}/api/status/1

### Create a status
POST {{baseUrl}}/api/status
Content-Type: application/json

{
  "StatusName": "Open"
}

### Update a status
PUT {{baseUrl}}/api/status/1
Content-Type: application/json

{
  "StatusName": "Closed"
}

### Delete a status
DELETE {{baseUrl}}/api/status/1



