# ─────────────────────────────────────────────────────────────────────────────
# OMM Backend — Environment Variables
# Copy this file to .env and fill in values as needed.
# Authentication relies on Application Default Credentials (ADC).
# Run: gcloud auth application-default login
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# BigQuery — set automatically in src/config/bigquery.js but can be overridden here
GCP_PROJECT_ID=activity-list-493220
BQ_DATASET_ID=AdminDataModel
